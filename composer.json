{
    "name": "kib-ev/laravel-ftp-deploy",
    "description": "Deploy Laravel project files to shared hosting via FTP (Artisan command)",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/kib-ev/laravel-ftp-deploy",
    "support": {
        "issues": "https://github.com/kib-ev/laravel-ftp-deploy/issues",
        "source": "https://github.com/kib-ev/laravel-ftp-deploy"
    },
    "keywords": [
        "laravel",
        "ftp",
        "deploy",
        "hosting",
        "upload"
    ],
    "require": {
        "php": "^8.1",
        "ext-ftp": "*",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "FtpDeploy\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FtpDeploy\\FtpDeployServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
